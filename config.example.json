    "refresh_token": ""
  },
  "options": {
    "poll_interval_seconds": 5,
    "tick_interval_seconds": 0.5,
    "min_patch_interval_seconds": 0.75,
    "heartbeat_seconds": 0,
    "username_format": "{track} — {artist}",
    "no_lyrics_text": "♪",
    "instrumental_text": "♪ Instrumental ♪",
    "show_when_paused": true
  }
}
